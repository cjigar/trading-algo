# ------------------------------------------------------------------------------
# Kotak Neo API credentials (SECRETS — copy to .env, never commit)
# TOTP auth: NeoAPI(access_token, neo_fin_key) -> totp_login(mobile, ucc, totp)
#            -> totp_validate(mpin).  Your web-login password/PAN are NOT used by the API.
# ------------------------------------------------------------------------------
# NEO-app access token: Invest -> Trade API -> Your Applications -> copy the token.
KOTAK_ACCESS_TOKEN=
KOTAK_MOBILE=+91XXXXXXXXXX
KOTAK_UCC=
KOTAK_MPIN=
# TOTP source — provide ONE of:
#   (a) base32 seed for unattended login (auto-generates the 6-digit code via pyotp), or
KOTAK_TOTP_SECRET=
#   (b) a CURRENT 6-digit code from your authenticator for a one-shot run (expires ~30s).
KOTAK_TOTP=
# Optional / not required by the TOTP API (kept for older SDK builds):
KOTAK_CONSUMER_KEY=
KOTAK_CONSUMER_SECRET=

# ------------------------------------------------------------------------------
# Runtime configuration (see algo_trading/config/settings.py for all options)
# ------------------------------------------------------------------------------
# paper (default, no real orders) or live (requires ALGO_CONFIRM_LIVE=YES to arm)
ALGO_MODE=paper
ALGO_CONFIRM_LIVE=

# Kotak environment: prod | uat
ALGO_KOTAK_ENVIRONMENT=prod

# --- Database ---
# Local dev/tests use SQLite at ALGO_DB_PATH. In Docker, ALGO_DATABASE_URL is set by
# docker-compose to point at the Postgres service (leave it blank here for local runs).
ALGO_DB_PATH=data/algo.db
ALGO_DATABASE_URL=

# Postgres credentials used by docker-compose (the db service + the app's DATABASE_URL).
POSTGRES_USER=algo
POSTGRES_PASSWORD=algo
POSTGRES_DB=algo

# Build the image with the Kotak SDK included (1) or not (0, default; paper mode works without).
INSTALL_BROKER=0

# --- Live feed: underlying index-spot instrument tokens ---
# Index tokens (looked up via search_scrip): NIFTY 50 = 26000 (nse_cm), SENSEX = 1 (bse_cm).
ALGO_NIFTY_INDEX_TOKEN=26000
ALGO_SENSEX_INDEX_TOKEN=1

# --- OI selling strategy: per-underlying config ---
# Underlyings the OI strategy trades; each gated to its own weekdays.
ALGO_OI_UNDERLYINGS=NIFTY,SENSEX
ALGO_ALLOWED_WEEKDAYS=FRI,MON,TUE   # NIFTY trading days
ALGO_SENSEX_WEEKDAYS=WED,THU        # SENSEX trading days
# Strike intervals: NIFTY 50, SENSEX 100 (ALGO_STRIKE_STEP / ALGO_SENSEX_STRIKE_STEP)

# --- Strategy parameters (PLACEHOLDERS — confirm exact values before going live) ---
ALGO_UNDERLYINGS=NIFTY,SENSEX
ALGO_CANDLE_TIMEFRAME_MINUTES=5
ALGO_LOTS=1
# Per-underlying lot size (0 = use the scrip master's value). Verified live: NIFTY 65, SENSEX 20.
ALGO_NIFTY_LOT_SIZE=65
ALGO_SENSEX_LOT_SIZE=20
ALGO_STRIKE_SELECTION=ATM          # ATM | OTM1 | OTM2 | ITM1 ...
ALGO_VWAP_BREAKOUT_BUFFER=0.0      # points beyond VWAP required to trigger
ALGO_TARGET_POINTS=30
ALGO_TRAIL_POINTS=10
ALGO_STOPLOSS_POINTS=15
ALGO_SQUAREOFF_TIME=15:15          # IST HH:MM hard square-off
ALGO_DAILY_LOSS_CAP=5000           # absolute rupees; kill-switch when breached
ALGO_MAX_POSITIONS=1
ALGO_MAX_TRADES_PER_DAY=5
ALGO_PRODUCT_TYPE=MIS              # MIS | NRML
ALGO_FLATTEN_ON_KILL_SWITCH=true
ALGO_STALE_FEED_SECONDS=15

# --- Web app (apps/api + apps/web) ---
WEB_AUTH_PASSWORD=changeme          # single-user login password
WEB_AUTH_SECRET=change-me-32-bytes  # JWT signing secret
WEB_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_BASE=http://localhost:8000
