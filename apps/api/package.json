{
  "name": "@trading-algo/api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "python -c \"import app.main\"",
    "lint": "ruff check app",
    "typecheck": "mypy app",
    "gen:types": "python -c \"import json,app.main; open('../web/lib/api-types-openapi.json','w').write(json.dumps(app.main.app.openapi()))\""
  }
}
