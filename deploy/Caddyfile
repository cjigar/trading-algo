# Caddy reverse proxy for the trading-algo dashboard.
#
# SITE_ADDRESS (set in .env) controls TLS:
#   - A domain, e.g. algo.example.com   -> Caddy auto-provisions a real Let's Encrypt cert.
#   - :443                              -> no domain; pair with `tls internal` below for a
#                                          self-signed cert (browser will warn once; fine for a
#                                          single-user IP-restricted dashboard).
#
# Access is expected to be firewalled to your own IP(s) (see deploy/DEPLOY.md).

{$SITE_ADDRESS} {
	encode gzip

	# If SITE_ADDRESS is :443 (IP only, no domain), uncomment the next line for a self-signed cert:
	# tls internal

	# API + health checks -> FastAPI backend (same origin, so the browser needs no CORS).
	@api path /api/* /health
	handle @api {
		reverse_proxy api:8000 {
			# SSE stream (/api/stream) needs unbuffered streaming.
			flush_interval -1
		}
	}

	# Everything else -> Next.js web app.
	handle {
		reverse_proxy web:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
