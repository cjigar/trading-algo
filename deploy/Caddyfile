# Caddy reverse proxy for the trading-algo dashboard.
#
# TLS depends on SITE_ADDRESS (set in .env):
#   - DOMAIN (e.g. algo.example.com): remove the `tls` line below — Caddy auto-provisions a real
#     Let's Encrypt cert. Clients send SNI, so on-demand/ACME certs work.
#   - IP ONLY (SITE_ADDRESS=:443): clients do NOT send SNI for a bare IP, so Caddy's on-demand
#     internal issuer can't pick a cert and the handshake fails. Use an explicit self-signed cert
#     with the IP in its SAN (the `tls` line below) — see deploy/DEPLOY.md for how to generate it.
#     The browser warns once ("proceed"); fine for a single-user IP-restricted dashboard.
#
# Access must be firewalled to your own IP via the DOCKER-USER chain — Docker-published ports
# BYPASS ufw, so a `ufw allow 443` rule does NOT restrict this. See deploy/DEPLOY.md.

{$SITE_ADDRESS} {
	encode gzip

	# IP-only self-signed cert (generated per deploy/DEPLOY.md). For a DOMAIN, delete this line.
	tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem

	# API + health checks -> FastAPI backend (same origin, so the browser needs no CORS).
	@api path /api/* /health
	handle @api {
		reverse_proxy api:8000 {
			# SSE stream (/api/stream) needs unbuffered streaming.
			flush_interval -1
		}
	}

	# Everything else -> Next.js web app.
	handle {
		reverse_proxy web:3000
	}

	header {
		# NO Strict-Transport-Security here. HSTS is only safe with a real, trusted cert: on the
		# IP-only self-signed setup (SITE_ADDRESS=:443) a cached HSTS entry makes the cert warning
		# NON-bypassable — the browser drops the "Proceed" option and the dashboard becomes
		# unreachable. Re-add HSTS only once SITE_ADDRESS is a DOMAIN with a Let's Encrypt cert.
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
